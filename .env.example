# Application Environment
NEXT_PUBLIC_APP_ENV=development
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_SECRET=your-api-secret-here
NEXT_PUBLIC_DOCSCRIVE_API=http://localhost:3003/api

# GitHub OAuth Configuration
NEXT_PUBLIC_GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_REDIRECT_URI=http://localhost:3000/api/auth/github/callback
GITHUB_WEBHOOK_SECRET=your-webhook-secret-optional

# Security
JWT_SECRET=your-jwt-secret-min-32-characters-long
SECURITY_HEADERS_ENABLED=true
CSP_ENABLED=true

# Database and Storage (Optional)
DATABASE_URL=
REDIS_URL=

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
GITHUB_RATE_LIMIT_MAX=5000
GITHUB_RATE_LIMIT_WINDOW=3600000

# Processing Limits
MAX_REPOSITORY_SIZE_MB=500
MAX_FILES_PER_REPO=1000
MAX_PROCESSING_TIME_MINUTES=30

# Analytics (Optional)
NEXT_PUBLIC_UMAMI_SCRIPT_URL=
NEXT_PUBLIC_UMAMI_WEBSITE_ID=

# Error Tracking (Optional)
NEXT_PUBLIC_SENTRY_DSN=

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Performance and Caching
ENABLE_CACHE=true
CACHE_TTL=3600
REPOSITORY_CACHE_TTL=1800
